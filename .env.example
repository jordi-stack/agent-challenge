# =============================================================
# Nosana x ElizaOS Agent Challenge — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# -------------------------------------------------------------
# LLM Configuration — Qwen3.5-27B via Nosana Inference Endpoint
# -------------------------------------------------------------
# Nosana provides a hosted Qwen3.5-27B endpoint for the challenge.
# Use the URL below for development. No GPU required locally.

OPENAI_API_KEY=nosana
OPENAI_BASE_URL=https://4ksj3tve5bazqwkuyqdhwdpcar4yutcuxphwhckrdxmu.node.k8s.prd.nos.ci/v1
OPENAI_API_URL=https://4ksj3tve5bazqwkuyqdhwdpcar4yutcuxphwhckrdxmu.node.k8s.prd.nos.ci/v1

# Model name as served by the Nosana endpoint
MODEL_NAME=Qwen/Qwen3.5-4B
OPENAI_SMALL_MODEL=Qwen/Qwen3.5-4B
OPENAI_LARGE_MODEL=Qwen/Qwen3.5-4B

# -------------------------------------------------------------
# Embedding Configuration — via Nosana Inference Endpoint
# -------------------------------------------------------------
OPENAI_EMBEDDING_URL=https://4yiccatpyxx773jtewo5ccwhw1s2hezq5pehndb6fcfq.node.k8s.prd.nos.ci/v1
OPENAI_EMBEDDING_API_KEY=nosana
OPENAI_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
OPENAI_EMBEDDING_DIMENSIONS=1024

# -------------------------------------------------------------
# Option B: Local development with Ollama (optional)
# -------------------------------------------------------------
# Install Ollama: https://ollama.com/download
# Then run: ollama pull qwen3.5:27b && ollama serve
#
# OPENAI_API_KEY=ollama
# OPENAI_API_URL=http://127.0.0.1:11434/v1
# MODEL_NAME=qwen3.5:27b

# -------------------------------------------------------------
# Agent Server Configuration
# -------------------------------------------------------------
SERVER_PORT=3000

# -------------------------------------------------------------
# Database (SQLite — sufficient for development)
# -------------------------------------------------------------
# Default: ./data/db.sqlite (created automatically)
# For production, consider a persistent storage solution.
# SQLITE_DATA_DIR=./data

# -------------------------------------------------------------
# Nosana API — live deployment monitoring
# -------------------------------------------------------------
# Get your API key from: deploy.nosana.com → Account
# Get DEPLOYMENT_ID from the Nosana dashboard after first deploy
# These enable live deployment status + credits on the Infrastructure page

NOSANA_API_KEY=nos_your_api_key_here
NOSANA_DEPLOYMENT_ID=your_deployment_id_here

# -------------------------------------------------------------
# Optional: CoinMarketCap API — real-time token price data for Analyst probe
# -------------------------------------------------------------
# Free tier: 333 calls/day — sufficient for normal usage
# Get key at: coinmarketcap.com/api
# If not set, Analyst falls back to Tavily web search results only
COINMARKETCAP_API_KEY=

# -------------------------------------------------------------
# Optional: Social Integrations (add plugins as needed)
# -------------------------------------------------------------
# Telegram bot — https://core.telegram.org/bots#creating-a-new-bot
# TELEGRAM_BOT_TOKEN=

# Discord bot — https://discord.com/developers/applications
# DISCORD_API_TOKEN=

# Twitter/X — https://developer.twitter.com
# TWITTER_USERNAME=
# TWITTER_PASSWORD=
# TWITTER_EMAIL=
